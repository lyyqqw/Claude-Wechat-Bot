 # Claude Agent SDK Configuration
 # ===========================
 # Claude Agent SDK uses Anthropic API format. Use a proxy service
 # (e.g. litellm, one-api, new-api) for format conversion if needed.

 # API key (required)
 ANTHROPIC_API_KEY=sk-your-api-key-here

 # API endpoint — Anthropic-compatible proxy address (required)
 # Direct DeepSeek native address won't work; proxy needed for format conversion
 # Examples:
 #   litellm:  http://localhost:4000
 #   one-api:  http://localhost:3000/v1
 ANTHROPIC_BASE_URL=

 # Default model (use /model command to switch dynamically)
 CLAUDE_MODEL=claude-sonnet-4-20250514

 # Available models list (comma-separated, for /model command)
 CLAUDE_MODELS=claude-sonnet-4-20250514,claude-sonnet-4-6

 # Claude request timeout (milliseconds, default 120000)
 #CLAUDE_TIMEOUT=360000

 # Long-poll timeout (seconds, default 60)
 #POLL_TIMEOUT=60

 # Management Panel (Web Dashboard)
 PANEL_PORT=3000           # Panel port (default 3000)
 PANEL_USERNAME=admin      # Login username
 PANEL_PASSWORD=admin123   # Login password
 #PANEL_SECRET=random-key   # JWT secret
