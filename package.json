{
  "name": "claude-code-wechat-bot",
  "version": "2.4.1",
  "description": "将 Claude Code 接入微信个人号 — 基于 Claude Agent SDK + 腾讯 iLink Bot API",
  "type": "module",
  "bin": {
    "claude-wechat": "./src/index.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/index.js",
    "login": "node src/auth.js",
    "add-bot": "node src/auth.js",
