  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@xmccln/wechat-ilink-sdk": "^1.0.4",
    "chalk": "^5.4.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "playwright": "^1.61.1",
    "puppeteer-core": "^25.3.0",
    "qrcode": "^1.5.4"
  }
}
